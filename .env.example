# Copy this file to .env and fill in your values.
# .env is gitignored — never commit model paths or secrets.

# Absolute path to the directory containing your GGUF model files.
MODELS_DIR=/data/ai/models

# Filename of the model within MODELS_DIR.
MODEL_FILE=your-model.gguf

# Number of MoE expert layers to keep on CPU.
# 0 = all experts on GPU (requires more VRAM).
# 35 works well for 32B+ MoE models on 24 GB VRAM.
CPU_MOE_LAYERS=35

# Context window in tokens.
# 8192 is safe for 24 GB VRAM with a large model.
# 262144 is the maximum supported but will OOM on most consumer GPUs.
CONTEXT_SIZE=8192
