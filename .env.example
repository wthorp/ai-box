# Copy this file to .env and fill in your values.
# .env is gitignored — never commit model paths or secrets.

# Absolute path to the directory containing your GGUF model files.
MODELS_DIR=/data/ai/models

# Filename of the model within MODELS_DIR.
MODEL_FILE=your-model.gguf

# Number of MoE expert layers to keep on CPU.
# 0 = all experts on GPU (requires more VRAM).
# 35 works well for 32B+ MoE models on 24 GB VRAM.
CPU_MOE_LAYERS=35

# Context window in tokens.
# 8192 is safe for 24 GB VRAM with a large model.
# 262144 is the maximum supported but will OOM on most consumer GPUs.
CONTEXT_SIZE=8192

# Optional TabbyAPI/EXL3 backend. The compose service mounts MODELS_DIR at
# /app/models, so TABBY_MODEL_NAME is a directory below MODELS_DIR.
# TABBY_MODEL_NAME=gemma-4-31b-dense-exl3
# Other local Gemma options:
# TABBY_MODEL_NAME=gemma-4-moe-exl3/gemma-4-moe-4.10bpw
# TABBY_MODEL_NAME=gemma-4-moe-exl3/gemma-4-moe-5.10bpw
# TABBY_MODEL_NAME=qwen3-coder-next-4.0bpw
# TABBY_CONTEXT_SIZE=32768
# TABBY_CACHE_SIZE=32768
# TABBY_CACHE_MODE=Q8
# TABBY_GPU_SPLIT=23.0
# TABBY_AUTOSPLIT_RESERVE_MIB=1024
# TABBY_TOOL_FORMAT=gemma4
# TABBY_OVERRIDE_PRESET=qsa_coding
# TABBY_TEMPERATURE=0.8
# TABBY_TOP_P=0.95
# TABBY_TOP_K=40
# TABBY_MIROSTAT=2
# TABBY_MIROSTAT_TAU=4.5
# TABBY_MIROSTAT_ETA=0.1
# TABBY_PRESENCE_PENALTY=0.02

# Hard cap for each inference container. Keep swap equal to memory so a bad
# model/context combination is OOM-killed instead of driving the host into swap.
# The defaults in docker-compose.yml are sized for the 96 GB reference machine.
# INFERENCE_MEMORY_LIMIT=88g
# INFERENCE_MEMORY_SWAP_LIMIT=88g

# Directory where benchmark results are written.
# Created automatically on first docker compose run.
EVAL_RESULTS_DIR=./eval-results

# Optional: host checkout of https://github.com/datacurve-ai/deep-swe.
# Used by ./deepswe-run.sh after quant/model tuning is stable.
# DEEPSWE_DIR=/data/ai/deep-swe

# Optional: host uv Python cache mounted into DeepSWE task containers (faster cold starts).
# Pier itself is installed in the runner image — no host install required.
# UV_PYTHON_CACHE_DIR=/home/you/.local/share/uv/python
